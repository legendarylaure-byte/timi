rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection — owner access only
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Channels — read by all auth'd, write by owner
    match /channels/{channelId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && resource.data.ownerId == request.auth.uid;
      allow create: if request.auth != null;
    }

    // Videos — read by all auth'd, create/update by any auth'd, delete by creator
    match /videos/{videoId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if request.auth != null && resource.data.createdBy == request.auth.uid;
    }

    // Backend-only collections — dashboard can read, only backend (unauthed) can write
    function isBackend() { return request.auth == null; }

    match /agents/{agentId} {
      allow read: if request.auth != null;
      allow write: if isBackend();
    }

    match /logs/{logId} {
      allow read: if request.auth != null;
      allow write: if isBackend();
    }

    match /analytics/{docId} {
      allow read: if request.auth != null;
      allow write: if isBackend();
    }

    match /series_plans/{docId} {
      allow read: if request.auth != null;
      allow write: if isBackend();
    }

    match /system/{docId} {
      allow read: if request.auth != null;
      allow write: if isBackend();
    }

    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if isBackend();
    }

    match /scheduled_posts/{docId} {
      allow read: if request.auth != null;
      allow write: if isBackend();
    }

    // User-facing collections — read/write by auth'd users
    match /settings/{docId} {
      allow read, write: if request.auth != null;
    }

    match /platform_settings/{docId} {
      allow read, write: if request.auth != null;
    }

    match /predictions/{docId} {
      allow read, write: if request.auth != null;
    }

    match /pipeline_triggers/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isBackend();
    }

    match /notifications/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    match /notif_preferences/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == docId;
    }

    // Dashboard collections — read by auth'd users, write by backend
    match /agent_status/{docId} {
      allow read: if request.auth != null;
      allow write: if isBackend();
    }

    match /activity_logs/{docId} {
      allow read: if request.auth != null;
      allow write: if isBackend();
    }

    match /trends/{docId} {
      allow read: if request.auth != null;
      allow write: if isBackend();
    }

    match /monetization/{docId} {
      allow read: if request.auth != null;
      allow write: if isBackend();
    }

    match /repurpose_jobs/{docId} {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.createdBy == request.auth.uid;
    }

    match /upload_queue/{docId} {
      allow read: if request.auth != null;
      allow write: if isBackend();
    }

    match /content_plan/{docId} {
      allow read: if request.auth != null;
      allow write: if isBackend();
    }

    match /series/{docId} {
      allow read: if request.auth != null;
      allow write: if isBackend();
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
