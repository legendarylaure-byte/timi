# ============================================
# VYOM AI CLOUD — ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# ============================================

# FIREBASE CONFIG (NEXT_PUBLIC_ prefix required for client-side access)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase/serviceAccountKey.json
FIREBASE_PROJECT_ID=

# GROQ API KEY (from console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# GEMINI API (fallback LLM)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OLLAMA (local LLM fallback)
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434

# HUGGINGFACE
HF_TOKEN=
HUGGINGFACE_TOKEN=

# YOUTUBE DATA API V3 (from Google Cloud Console)
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/auth/youtube/callback
YOUTUBE_CPM=3.0

# TIKTOK API (from developers.tiktok.com)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:3000/api/auth/tiktok/callback
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=

# INSTAGRAM / FACEBOOK GRAPH API (from developers.facebook.com)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
INSTAGRAM_ACCOUNT_ID=

# STOCK VIDEO APIs
PEXELS_API_KEY=
PIXABAY_API_KEY=

# TELEGRAM BOT (from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SERVERLESS GPU (Modal or Replicate)
MODAL_API_KEY=
MODAL_API_SECRET=
REPLICATE_API_TOKEN=

# CLOUDFLARE R2 STORAGE (replaces Firebase Storage for videos)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=vyom-ai-videos

# APP CONFIG
NEXT_PUBLIC_APP_NAME=Vyom Ai Cloud
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# PIPELINE CONFIG
SCHEDULE_SHORTS_PER_DAY=2
SCHEDULE_LONG_PER_DAY=2
SHORTS_MAX_DURATION=120
LONG_MAX_DURATION=600
PIPELINE_TIMEOUT_MINUTES=30
MAX_RETRIES_PER_TOPIC=2
AUTO_APPROVE_THRESHOLD=80

# FEATURE FLAGS
ENABLE_MULTI_LANG=true
ENABLE_SUBTITLES=true
ENABLE_REVIEW_GATE=true
USE_MUSICGEN=true

# PATH CONFIG
PYTHON_PATH=
FFMPEG_PATH=
FFPROBE_PATH=
