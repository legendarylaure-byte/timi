# ============================================
# VYOM AI CLOUD — AGENT ENVIRONMENT VARIABLES
# ============================================
# Copy this file to agents/.env and fill in your values
# ============================================

# OLLAMA (primary LLM — no API keys needed)
OLLAMA_MODEL=qwen3.5:9b
# Docker: http://host.docker.internal:11434
# Local:  http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# GROQ API (fallback LLM — leave empty to skip)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# GEMINI API (fallback LLM — leave empty to skip)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# FIREBASE
FIREBASE_PROJECT_ID=timi-childern-stories
# Option A: base64-encoded service account JSON (preferred for CI/Docker)
FIREBASE_SERVICE_ACCOUNT_KEY=
# Option B: path to service account file (used if KEY is empty)
FIREBASE_SERVICE_ACCOUNT_PATH=firebase/serviceAccountKey.json

# YOUTUBE DATA API V3
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/auth/youtube/callback

# YOUTUBE ANALYTICS & REVENUE
YOUTUBE_CPM=8.0

# TIKTOK PUBLISHING
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=

# INSTAGRAM / FACEBOOK PUBLISHING
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
INSTAGRAM_ACCOUNT_ID=

# STOCK VIDEO APIS
PEXELS_API_KEY=
PIXABAY_API_KEY=

# TELEGRAM BOT NOTIFICATIONS
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# CLOUDFLARE R2 STORAGE
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=vyom-ai-videos

# FFMPEG PATHS (defaults: auto-detected via PATH)
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# FEATURE FLAGS
ENABLE_MULTI_LANG=false
MULTI_LANG_CODES=es,fr,de,pt,hi
ENABLE_SUBTITLES=false
ENABLE_REVIEW_GATE=true
ENABLE_DIRECTOR_REVIEW=true
AUTO_APPROVE_THRESHOLD=80
ENABLE_AUTO_REPLY=true
ENABLE_COMMUNITY_POSTS=false
ENABLE_UPSCALE=false
SCENE_ARCHITECT_MODE=advisory

# SCHEDULING
SCHEDULE_SHORTS_PER_DAY=3
SCHEDULE_LONG_PER_DAY=1
MAX_RETRIES_PER_TOPIC=3
PIPELINE_TIMEOUT_MINUTES=90

# LTX VIDEO MODEL
VIDEO_MODEL=ltx
LTX_MODEL_DIR=~/ltx-models
LTX_ENGINE=mlx
LTX_LOW_RAM=true
LTX_GEMMA_MODEL=mlx-community/gemma-3-12b-it-4bit
LTX_DISTILLED_LORA=ltx-2.3-22b-distilled-lora-384-1.1.safetensors

# VOICE
VOICE_PROVIDER=kokoro
GOOGLE_APPLICATION_CREDENTIALS=

# KOKORO TTS (local, free, no API key needed)
KOKORO_VOICE=af_bella
KOKORO_REPO_ID=hexgrad/Kokoro-82M

# EDGE TTS (online, used as fallback for timing)

# SFX (sound effects mixed into final audio)
SFX_ENABLED=true
SFX_VOLUME_DB=-12

# COMPANION PAGES (self-contained HTML pages uploaded to R2 per video)
ENABLE_COMPANION_PAGES=true

# SENTRY
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# VISUAL QA (frame-level quality checks after compositing)
ENABLE_VISUAL_QA=true
QA_BLACK_THRESHOLD=0.2
QA_FREEZE_THRESHOLD=0.1
QA_MAX_RETRIES=2

# PIPELINE CONFIG
USE_ANIMATION_ENGINE=true
LONG_MAX_DURATION=180
SLOT=
AGENT_LLM_ROUTES={}
USE_MUSICGEN=false
